# SOK scripts/ .gitignore
# Secrets, logs, and generated artifacts — never committed

# Credentials and secrets
*.key
*.pem
*.pfx
.env
.env.*
credentials.json
client_secret*.json
**/.credentials/
**/secrets/

# SOK runtime logs (written to SOK/Logs/, but guard anyway)
**/Logs/
**/_history.json
**/_history.json.bak
**/_history.json.lock
**/*.corrupted_*
**/TestBatch/

# Transcript pollution (WinPS policy leak into CWD)
Users/shelc/Documents/WindowsPowershell/
**/PowerShell_transcript.*.txt

# Deprecated folder is tracked but old archives inside are big — allow but flag
# (leaving rule commented; decide per-commit)
# Deprecated/**/*.zip
# Deprecated/**/*.7z

# Python / uvx cache
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS cruft
Thumbs.db
Desktop.ini
.DS_Store

# Editor
.vscode/
.idea/
*.swp
*~

# Nested third-party git repos (not submodules) — exclude rather than embed
Sublist3r/

# Accidental shell-redirect stray files (empty or near-empty, unhelpful names)
# These were auto-generated by commands like `some-cmd > 1` or `echo 0 > 5`.
/1
/5
/Redundancy

